# LinkedIn Recruiter Outreach Automation
# Environment Variables Template
# Copy this to .env and fill in your values

# ============================================
# LINKEDIN AUTHENTICATION (Simple Method)
# ============================================
# Get your li_at cookie value from LinkedIn:
#   1. Open LinkedIn in your browser and login
#   2. Press F12 → Application tab → Cookies → linkedin.com
#   3. Find the 'li_at' cookie and copy its Value
#   4. Paste the value below (just the value, no quotes needed)
LINKEDIN_LI_AT=your_li_at_cookie_value_here

# ============================================
# TELEGRAM NOTIFICATIONS
# ============================================
# Create a bot via @BotFather, get the token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get your chat ID by messaging @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# AI CONFIGURATION (Optional)
# ============================================
# Gemini API key for AI-powered search queries
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name (recommended: gemini-3-flash)
GEMINI_MODEL=gemini-3-flash

# ============================================
# AUTOMATION SETTINGS
# ============================================
# Maximum invites to send per day (default: 14)
DAILY_INVITE_LIMIT=14

# Schedule time in HH:MM format (IST timezone)
SCHEDULE_TIME=09:30

# Priority locations (comma-separated)
PRIORITY_LOCATIONS=United States,Canada,Australia

# ============================================
# BROWSER SETTINGS
# ============================================
# Run browser in headless mode (true/false)
# Set to false for debugging
HEADLESS=true

# Optional proxy for LinkedIn requests (recommended for CI runners)
# Examples:
# LINKEDIN_PROXY=http://user:pass@host:port
# LINKEDIN_PROXY=socks5://host:port
LINKEDIN_PROXY=

# On GitHub Actions, try undetected-chromedriver before Selenium driver
PREFER_UC_IN_GHA=true

# Random delay range in seconds between actions
MIN_DELAY=3
MAX_DELAY=8

# Login retry behavior (helps with transient redirect-loop/rate-limit pages)
LOGIN_MAX_ATTEMPTS=3
LOGIN_RETRY_BASE_DELAY=20
